{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true,
		"ignore": [".astro", ".husky", ".vercel", "dist"]
	},
	"formatter": {
		"enabled": true,
		"ignore": [".astro", ".husky", ".vercel", "dist"]
	},
	"linter": {
		"enabled": true,
		"ignore": [".astro", ".husky", ".vercel", "dist"],
		"rules": {
			"recommended": true
		}
	},
	"css": {
		"linter": {
			"enabled": true
		},
		"formatter": {
			"enabled": true
		}
	}
}
